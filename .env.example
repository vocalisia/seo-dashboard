# Copy to .env.local and fill (never commit .env.local).
# Restore from Vercel: npm run env:pull   (same as npx vercel env pull .env.local)

# Local dev only (next dev): login form on /login — disabled in production builds
NEXT_PUBLIC_SHOW_DEV_LOGIN=true
LOCAL_DEV_EMAIL=admin@localhost
LOCAL_DEV_PASSWORD=change-me-in-env-local

# Database (PostgreSQL — Neon ou local). Vide en dev → mode démo automatique (sans Vercel).
DATABASE_URL=

# En development uniquement : si "true", pas de données de démo — erreur si DATABASE_URL vide.
# LOCAL_DEV_REQUIRE_DB=

# Auth (generate: openssl rand -base64 32)
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google service account (GSC / APIs) — JSON string or use GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_PRIVATE_KEY in code paths that support it
GOOGLE_CREDENTIALS=

# AI
MAMMOUTH_API_KEY=
OPENAI_API_KEY=

# GitHub API (repos, autopilot publish)
GITHUB_TOKEN=
GITHUB_OWNER=

# Other integrations
APIFY_API_KEY=
RESEND_API_KEY=

# Optional: YouTube, etc.
# YOUTUBE_API_KEY=

# ── GSC Weekly Cron ───────────────────────────────────────────────────────────
# CRON_SECRET — random 32+ chars, set in Vercel env + curl header
# Generate: openssl rand -hex 32
CRON_SECRET=

# Email provider (Brevo preferred, Resend fallback — RESEND_API_KEY already above)
BREVO_API_KEY=

# IndexNow key (already deployed on all Vault 369 sites)
INDEXNOW_KEY=551683f27598a229d3e9dc91cb786208

# Alert recipient email (default: cohenrichard07@gmail.com)
ALERT_EMAIL=cohenrichard07@gmail.com
